{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c).on('end',()=>{const f=(JSON.parse(d).tool_input||{}).file_path||'';if(f.endsWith('.cs'))require('child_process').spawnSync('dotnet',['csharpier',f],{stdio:'inherit'})})\"",
            "timeout": 30,
            "statusMessage": "Running CSharpier..."
          }
        ]
      }
    ]
  }
}
